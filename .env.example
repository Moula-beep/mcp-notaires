PORT=3000
NODE_ENV=development

# llm provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# datagouv connector mode: "mcp" or "http"
DATAGOUV_MODE=http

# Optional MCP proxy endpoint that relays tool calls to the user-datagouv server.
# Expected payload:
# { "server": "user-datagouv", "toolName": "...", "arguments": { ... } }
MCP_PROXY_URL=
MCP_PROXY_TOKEN=

# Optional for Vercel: set NODE_ENV=production in project settings
